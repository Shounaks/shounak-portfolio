{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "rm *": "ask",
      "grep *": "allow"
    }
  },
  "mcp": {
    "next-devtools-mcp": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true
    },
	"tailwind-mcp": {
      "type": "local",
      "command": ["npx", "-y", "tailwindcss-mcp-server"],
      "enabled": true
    },
	"shadcn": {
	  "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
	  "enabled": true
    }
  }
}